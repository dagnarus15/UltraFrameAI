<Window x:Class="UltraFrameAI.RenderPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="Preview"
        Icon="pack://application:,,,/images/icon.png"
        Width="1440"
        Height="900"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#050A12"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0B1220"
                BorderBrush="#1D2940"
                BorderThickness="1"
                CornerRadius="18"
                Padding="16"
                ClipToBounds="True">
            <Grid>
                <TextBlock Text="{Binding PreviewLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="18"
                           FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#03070E"
                BorderBrush="#1D2940"
                BorderThickness="1"
                CornerRadius="18"
                ClipToBounds="True">
            <Grid>
                <Image x:Name="PreviewImage"
                       Source="{Binding PreviewSource}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <Border VerticalAlignment="Top"
                        Height="1"
                        Background="#22FFFFFF"
                        Margin="12,12,12,0" />
                <Border VerticalAlignment="Bottom"
                        Height="1"
                        Background="#12FFFFFF"
                        Margin="12,0,12,12" />
            </Grid>
        </Border>
    </Grid>
</Window>
