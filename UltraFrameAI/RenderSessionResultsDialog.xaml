<Window x:Class="UltraFrameAI.RenderSessionResultsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc RenderSessionResultsTitle}"
        Width="820"
        Height="620"
        MinWidth="760"
        MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{local:Loc RenderSessionResultsTitle}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="2"
                           Text="{Binding SummaryText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />

                <ItemsControl Grid.Row="4"
                              ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0E1628"
                                    BorderBrush="#223552"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding CompletionText}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding AverageFpsText}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="6"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap">
                    <Run Text="{local:Loc RenderSessionResultsDonatePrefix}" />
                    <Hyperlink Click="Donate_Click">
                        <Run Text="{local:Loc RenderSessionResultsDonateLink}" />
                    </Hyperlink>
                    <Run Text="{local:Loc RenderSessionResultsDonateSuffix}" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
