<Window x:Class="UltraFrameAI.StartupBenchmarkPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc StartupBenchmarkPromptTitle}"
        Width="860"
        SizeToContent="Height"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        PreviewMouseDown="Window_PreviewMouseDown"
        Closing="Window_Closing">
    <Window.Resources>
        <local:LanguageEqualsConverter x:Key="LanguageEqualsConverter" />
        <Style x:Key="LanguageMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22375B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16243D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#0B1220"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{local:Loc StartupBenchmarkPromptTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc StartupBenchmarkPromptGreeting}"
                                       Margin="0,8,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc StartupBenchmarkPromptThanks}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{local:Loc StartupBenchmarkPromptBody}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="i"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Top"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="12,0,0,0">
                    <Button x:Name="LanguageButton"
                            Width="42"
                            Height="30"
                            Padding="0"
                            Background="#13203A"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            ToolTip="{local:Loc Language}"
                            Click="LanguageButton_Click">
                        <Image Source="{Binding CurrentLanguageFlagPath}" Width="24" Height="16" />
                    </Button>
                    <Popup x:Name="LanguagePopup"
                           PlacementTarget="{Binding ElementName=LanguageButton}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border x:Name="LanguagePopupBorder"
                                Width="220"
                                Padding="8"
                                CornerRadius="14"
                                Background="#0E1628"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="LanguagePopupScale" ScaleX="0.96" ScaleY="0.96" />
                                    <TranslateTransform x:Name="LanguagePopupTranslate" Y="10" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <StackPanel>
                                <Button Command="{Binding SetLanguageCommand}"
                                        CommandParameter="English"
                                        Click="LanguageChoice_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=English}" Value="True">
                                                    <Setter Property="Background" Value="#16243D" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <DockPanel>
                                        <TextBlock Text="EN" FontWeight="SemiBold" />
                                        <TextBlock Text="{local:Loc LanguageEnglish}" Margin="10,0,0,0" />
                                    </DockPanel>
                                </Button>
                                <Button Command="{Binding SetLanguageCommand}"
                                        CommandParameter="Russian"
                                        Click="LanguageChoice_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=Russian}" Value="True">
                                                    <Setter Property="Background" Value="#16243D" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <DockPanel>
                                        <TextBlock Text="RU" FontWeight="SemiBold" />
                                        <TextBlock Text="{local:Loc LanguageRussian}" Margin="10,0,0,0" />
                                    </DockPanel>
                                </Button>
                                <Button Command="{Binding SetLanguageCommand}"
                                        CommandParameter="German"
                                        Click="LanguageChoice_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=German}" Value="True">
                                                    <Setter Property="Background" Value="#16243D" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <DockPanel>
                                        <TextBlock Text="DE" FontWeight="SemiBold" />
                                        <TextBlock Text="{local:Loc LanguageGerman}" Margin="10,0,0,0" />
                                    </DockPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="#0E1628"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#22344D"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{local:Loc HardwareAssessmentTitle}"
                               Style="{StaticResource CaptionStyle}" />
                    <ItemsControl ItemsSource="{Binding AssessmentLines}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#101A2B"
                                        BorderBrush="#223552"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Verdict}" Margin="0,4,0,0" Foreground="{StaticResource WarningBrush}" />
                                        <TextBlock Text="{Binding Detail}" Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="2"
                        Content="{local:Loc StartupBenchmarkPromptSkip}"
                        Click="Skip_Click"
                        Height="48"
                        MinWidth="180"
                        Background="#16243D"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
                <Button Grid.Column="4"
                        Content="{local:Loc StartupBenchmarkPromptRun}"
                        Click="Run_Click"
                        Height="48"
                        MinWidth="180"
                        Background="#1F3A52"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>
