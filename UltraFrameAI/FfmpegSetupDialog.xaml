<Window x:Class="UltraFrameAI.FfmpegSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Width="620"
        SizeToContent="Height"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource AppBgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18">
            <Border Style="{StaticResource CardStyle}"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding DialogTitle}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="FF"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="16,0,0,0" />

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Text="{Binding DialogMessage}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <StackPanel Grid.Row="4"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="{Binding ContinueWithoutText}"
                                MinWidth="140"
                                Margin="0,0,10,0"
                                Click="ContinueWithout_Click" />
                        <Button Content="{Binding ChooseFolderText}"
                                MinWidth="160"
                                Margin="0,0,10,0"
                                Click="ChooseFolder_Click" />
                        <Button Content="{Binding DownloadText}"
                                MinWidth="160"
                                Background="{StaticResource AccentBrush}"
                                Click="Download_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
