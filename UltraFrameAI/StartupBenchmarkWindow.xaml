<Window x:Class="UltraFrameAI.StartupBenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc StartupBenchmarkProgressTitle}"
        Width="760"
        Height="420"
        MinWidth="680"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Closing="Window_Closing">
    <Border Background="{DynamicResource AppBgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18"
              Background="{DynamicResource AppBgBrush}">
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{local:Loc StartupBenchmarkProgressTitle}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="2"
                           Text="{local:Loc StartupBenchmarkProgressIntro}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           Margin="0,42,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap">
                    <Run Text="{local:Loc StartupBenchmarkCurrentGpu}" />
                    <Run Text=": " />
                    <Run Text="{Binding BenchmarkGpuLabel}" />
                </TextBlock>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc StartupBenchmarkCurrentPhase}"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding CurrentPhase}"
                                   Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{local:Loc StartupBenchmarkCurrentSettings}"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding CurrentCase}"
                                   Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="6">
                    <TextBlock Text="{Binding CurrentDetail}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <ProgressBar Height="16"
                                 Margin="0,12,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding CurrentProgress, Mode=OneWay}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{local:Loc QueueProgress}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CurrentProgressText}"
                                       Margin="0,4,0,0"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Loc QueueElapsed}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CurrentElapsedText}"
                                       Margin="0,4,0,0"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="{local:Loc QueueETA}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding CurrentEtaText}"
                                       Margin="0,4,0,0"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="8"
                        Content="{local:Loc StartupBenchmarkCancel}"
                        HorizontalAlignment="Right"
                        MinWidth="110"
                        Padding="14,8"
                        Click="Cancel_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
