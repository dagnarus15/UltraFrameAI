<Window x:Class="UltraFrameAI.HelpCenterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc GeneralHelpTitle}"
        Icon="/Assets/UltraFrameAI.ico"
        Width="980"
        Height="760"
        MinWidth="900"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#0B1220">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="HelpTabButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="40" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="18">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="50"
                            Height="50"
                            CornerRadius="12"
                            Background="#13203A"
                            BorderBrush="#243451"
                            BorderThickness="1"
                            Margin="0,0,14,0"
                            VerticalAlignment="Top">
                        <Image Source="pack://application:,,,/images/logo.png"
                               Margin="8"
                               Stretch="Uniform" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{local:Loc GeneralHelpTitle}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{local:Loc HelpCenterIntro}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="760" />
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,10,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{local:Loc HelpCenterAppVersionLabel}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding AppVersionText}"
                                       Margin="8,0,0,0"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Button Content="{local:Loc HelpCenterLibraryVersions}"
                                    Margin="14,0,0,0"
                                    Padding="12,6"
                                    Click="LibraryVersions_Click" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2"
              Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{local:Loc HelpCenterHowToTab}"
                    Click="HowTo_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HelpTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static local:HelpCenterTab.HowTo}">
                                <Setter Property="Background" Value="#16314F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="2"
                    Content="{local:Loc HelpCenterFaqTab}"
                    Click="Faq_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HelpTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static local:HelpCenterTab.Faq}">
                                <Setter Property="Background" Value="#16314F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="4"
                    Content="{local:Loc HelpCenterHardwareTab}"
                    Click="Hardware_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HelpTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static local:HelpCenterTab.Hardware}">
                                <Setter Property="Background" Value="#16314F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="6"
                    Content="{local:Loc HelpCenterLinksTab}"
                    Click="Links_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HelpTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static local:HelpCenterTab.Links}">
                                <Setter Property="Background" Value="#16314F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="8"
                    Content="{local:Loc HelpCenterDonateTab}"
                    Click="Donate_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HelpTabButtonStyle}">
                        <Setter Property="Margin" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab}" Value="{x:Static local:HelpCenterTab.Support}">
                                <Setter Property="Background" Value="#16314F" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid Visibility="{Binding IsHowToVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{local:Loc HelpCenterHowToTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc HelpCenterHowToBody}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Visibility="{Binding IsFaqVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{local:Loc HelpCenterFaqTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding FaqEntries}"
                                          Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8"
                                                  Background="#101A2B"
                                                  BorderBrush="#223552"
                                                  BorderThickness="1"
                                                  Foreground="{StaticResource TextPrimaryBrush}">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding Question}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                            </Expander.Header>
                                            <Border Padding="12,10,12,12"
                                                    Background="#0E1628"
                                                    BorderBrush="#223552"
                                                    BorderThickness="1,1,1,0">
                                                <TextBlock Text="{Binding Answer}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Border>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Visibility="{Binding IsHardwareVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{local:Loc HardwareAssessmentTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding HardwareLines}"
                                          Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#101A2B"
                                                BorderBrush="#223552"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Verdict}" Margin="0,4,0,0" Foreground="{StaticResource WarningBrush}" />
                                                <TextBlock Text="{Binding Detail}" Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{local:Loc HelpCenterDetectedDevicesTitle}"
                                       Margin="0,14,0,8"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <Border Background="#0E1628"
                                    BorderBrush="#223552"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <ScrollViewer MaxHeight="240"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <ItemsControl ItemsSource="{Binding HardwareDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#101A2B"
                                                        BorderBrush="#223552"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="10"
                                                        Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding MemoryText}"
                                                                   Margin="0,6,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Visibility="{Binding IsSupportVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{local:Loc DonationDialogTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc DonationDialogThanks}"
                                       Margin="0,10,0,0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc DonationDialogBody}"
                                       Margin="0,8,0,12"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ItemsControl ItemsSource="{Binding DonationEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#101A2B"
                                                BorderBrush="#223552"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Value}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Note}"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Visibility="{Binding IsLinksVisible, Converter={StaticResource BoolToVisibility}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{local:Loc HelpCenterLinksTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{local:Loc HelpCenterLinksContacts}"
                                       Margin="0,12,0,8"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding ContactLinks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#101A2B"
                                                BorderBrush="#223552"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Url}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Note}"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{local:Loc HelpCenterLinksSources}"
                                       Margin="0,14,0,8"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding SourceLinks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#101A2B"
                                                BorderBrush="#223552"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Url}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Note}"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
