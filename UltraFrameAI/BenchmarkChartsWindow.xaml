<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="UltraFrameAI.BenchmarkChartsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc BenchmarkChartsWindowTitle}"
        Width="1660"
        Height="1040"
        MinWidth="1480"
        MinHeight="920"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="BenchmarkCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="BenchmarkSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="BenchmarkCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="BenchmarkModeButtonBaseStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#223552" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkModeButtonLeftStyle" TargetType="ToggleButton" BasedOn="{StaticResource BenchmarkModeButtonBaseStyle}">
            <Setter Property="Margin" Value="0,0,-1,0" />
            <Setter Property="BorderThickness" Value="1,1,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11,0,0,11"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkModeButtonRightStyle" TargetType="ToggleButton" BasedOn="{StaticResource BenchmarkModeButtonBaseStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0,1,1,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,11,11,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#101A2B" />
            <Setter Property="BorderBrush" Value="#223552" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource BenchmarkCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{local:Loc BenchmarkChartsWindowTitle}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{local:Loc BenchmarkChartsWindowHint}"
                               Margin="0,4,0,0"
                               Style="{StaticResource BenchmarkCaptionStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="{local:Loc BenchmarkWinnerTitle}"
                               Style="{StaticResource BenchmarkSectionTitleStyle}" />
                    <TextBlock Text="{local:Loc BenchmarkWeightedRecommendationLabel}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding BestOverallText}"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{local:Loc BenchmarkBestQualityTimeLabel}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding BestQualityTimeText}"
                               Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.18*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.82*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource BenchmarkCardStyle}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{local:Loc BenchmarkScatterTitle}"
                                   Style="{StaticResource BenchmarkSectionTitleStyle}" />
                        <ItemsControl Grid.Column="2"
                                      ItemsSource="{Binding LegendItems}"
                                      HorizontalAlignment="Right">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#101A2B"
                                            BorderBrush="#223552"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="8,4"
                                            Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding Brush}"
                                                     Stroke="{StaticResource TextPrimaryBrush}"
                                                     StrokeThickness="0.8"
                                                     Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                    <Grid Grid.Row="1"
                          x:Name="ScatterHost"
                          Margin="0,10,0,0"
                          ClipToBounds="True">
                        <Canvas x:Name="ScatterCanvas"
                                Background="#0E1628"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        <TextBlock Text="{local:Loc BenchmarkNoResults}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasResults}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource BenchmarkCardStyle}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{local:Loc BenchmarkHistogramTitle}"
                               Style="{StaticResource BenchmarkSectionTitleStyle}" />
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ItemsControl ItemsSource="{Binding RankingLegendItems}"
                                      HorizontalAlignment="Left">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#101A2B"
                                            BorderBrush="#223552"
                                            BorderThickness="1"
                                            CornerRadius="999"
                                            Padding="8,4"
                                            Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Fill="{Binding Brush}"
                                                     Stroke="{StaticResource TextPrimaryBrush}"
                                                     StrokeThickness="0.8"
                                                     Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{local:Loc BenchmarkSortLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,8,0" />
                            <ToggleButton Content="{local:Loc BenchmarkSortMetric}"
                                          IsChecked="{Binding IsMetricRanking, Mode=OneWay}"
                                          Style="{StaticResource BenchmarkModeButtonLeftStyle}"
                                          Click="SetMetricRanking_Click" />
                            <ToggleButton Content="{local:Loc BenchmarkSortName}"
                                          IsChecked="{Binding IsNameRanking, Mode=OneWay}"
                                          Style="{StaticResource BenchmarkModeButtonRightStyle}"
                                          Click="SetNameRanking_Click" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2"
                          x:Name="HistogramHost"
                          Margin="0,10,0,0"
                          ClipToBounds="True">
                        <ScrollViewer x:Name="HistogramScrollHost"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <Canvas x:Name="HistogramCanvas"
                                    Background="#0E1628"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top" />
                        </ScrollViewer>
                        <TextBlock Text="{local:Loc BenchmarkNoResults}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasResults}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
