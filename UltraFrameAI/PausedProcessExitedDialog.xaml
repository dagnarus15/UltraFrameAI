<Window x:Class="UltraFrameAI.PausedProcessExitedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc PausedProcessExitedTitle}"
        Width="720"
        SizeToContent="Height"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Closing="Window_Closing">
    <Border Background="#0B1220"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc PausedProcessExitedTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MessageText}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="!"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WarningBrush}"
                               VerticalAlignment="Top"
                               Margin="18,0,0,0" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#0E1628"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#22344D"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{local:Loc PausedProcessExitedFileLabel}"
                               Style="{StaticResource CaptionStyle}" />
                    <TextBlock Text="{Binding FileName}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Background="#0E1628"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#22344D"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{local:Loc PausedProcessExitedProcessLabel}"
                               Style="{StaticResource CaptionStyle}" />
                    <TextBlock Text="{Binding ProcessName}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Button Grid.Row="6"
                    Content="{local:Loc PausedProcessExitedOk}"
                    Click="Ok_Click"
                    Height="48"
                    MinWidth="180"
                    Background="#1F3A52"
                    BorderBrush="{StaticResource AccentBrush}"
                    Foreground="{StaticResource TextPrimaryBrush}" />
        </Grid>
    </Border>
</Window>
