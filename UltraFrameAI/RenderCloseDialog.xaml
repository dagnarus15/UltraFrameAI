<Window x:Class="UltraFrameAI.RenderCloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc CloseDuringRenderTitle}"
        Width="680"
        SizeToContent="Height"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        Closing="Window_Closing">
    <Border Margin="0"
            Background="#0B1220"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc CloseDuringRenderTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MessageText}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="!"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WarningBrush}"
                               VerticalAlignment="Top"
                               Margin="18,0,0,0" />
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Content="{local:Loc CloseDuringRenderStop}"
                        Click="Stop_Click"
                        Height="48"
                        MinWidth="190"
                        Background="#1F3A52"
                        BorderBrush="{StaticResource AccentBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
                <Button Grid.Column="2"
                        Content="{local:Loc CloseDuringRenderKeep}"
                        Click="Keep_Click"
                        Height="48"
                        MinWidth="190"
                        Background="#16243D"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>
