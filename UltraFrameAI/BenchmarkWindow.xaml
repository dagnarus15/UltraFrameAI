<Window x:Class="UltraFrameAI.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc BenchmarkWindowTitle}"
        Width="1460"
        Height="980"
        MinWidth="1220"
        MinHeight="840"
        WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="BenchmarkCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="BenchmarkSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="BenchmarkCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="BenchmarkButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="14,9" />
        </Style>

        <Style x:Key="BenchmarkModeButtonBaseStyle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#223552" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkModeButtonLeftStyle" TargetType="ToggleButton" BasedOn="{StaticResource BenchmarkModeButtonBaseStyle}">
            <Setter Property="Margin" Value="0,0,-1,0" />
            <Setter Property="BorderThickness" Value="1,1,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11,0,0,11"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkModeButtonRightStyle" TargetType="ToggleButton" BasedOn="{StaticResource BenchmarkModeButtonBaseStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0,1,1,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,11,11,0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B5A8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkStepRowStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#223552" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#13253F" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#0F1E2E" />
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkStartButtonStyle" TargetType="Button" BasedOn="{StaticResource BenchmarkButtonStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BenchmarkStopButtonStyle" TargetType="Button" BasedOn="{StaticResource BenchmarkButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoResultsOverlayStyle" TargetType="TextBlock" BasedOn="{StaticResource BenchmarkCaptionStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasResults}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BenchmarkToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#101A2B" />
            <Setter Property="BorderBrush" Value="#223552" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource BenchmarkCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{local:Loc Benchmark}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{local:Loc BenchmarkHint}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource BenchmarkCaptionStyle}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentStepText}"
                               VerticalAlignment="Top"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontWeight="SemiBold" />
                </Grid>

                        <Border Grid.Row="2"
                        Background="#101A2B"
                        BorderBrush="#223552"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{local:Loc BenchmarkWinnerTitle}"
                                       Style="{StaticResource BenchmarkSectionTitleStyle}" />
                            <TextBlock Text="{local:Loc BenchmarkWeightedRecommendationLabel}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding BestOverallText}"
                                       Margin="0,4,0,0"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{local:Loc BenchmarkBestQualityTimeLabel}"
                                       Style="{StaticResource BenchmarkSectionTitleStyle}" />
                            <TextBlock Text="{Binding BestQualityTimeText}"
                                       Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{local:Loc BenchmarkChartsHint}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{local:Loc BenchmarkSourceFileLabel}"
                                   Style="{StaticResource BenchmarkCaptionStyle}" />
                        <TextBlock Text="{local:Loc BenchmarkSourceFileHint}"
                                   Margin="0,4,0,8"
                                   Style="{StaticResource BenchmarkCaptionStyle}"
                                   TextWrapping="Wrap" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SourcePathTextBox"
                                     Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Content="{local:Loc BrowseFile}"
                                    Margin="10,0,0,0"
                                    Click="BrowseSourceFile_Click" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{local:Loc BenchmarkOutputLabel}"
                                           Style="{StaticResource BenchmarkCaptionStyle}" />
                                <TextBlock Text="{local:Loc BenchmarkOutputHint}"
                                           Margin="0,4,0,8"
                                           Style="{StaticResource BenchmarkCaptionStyle}"
                                           TextWrapping="Wrap" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Content="{local:Loc Browse}"
                                            Margin="10,0,0,0"
                                            Click="BrowseOutput_Click" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{local:Loc BenchmarkSampleSeconds}"
                                           Style="{StaticResource BenchmarkCaptionStyle}" />
                                <TextBox Text="{Binding SampleSecondsText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <TextBlock Text="{local:Loc BenchmarkQualityNote}"
                                       Style="{StaticResource BenchmarkCaptionStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{local:Loc BenchmarkStart}"
                                    Style="{StaticResource BenchmarkStartButtonStyle}"
                                    Background="{StaticResource AccentBrush}"
                                    Margin="0,0,8,0"
                                    Click="StartBenchmark_Click"
                                    IsEnabled="{Binding HasSource}" />
                            <Button Content="{local:Loc BenchmarkStop}"
                                    Style="{StaticResource BenchmarkStopButtonStyle}"
                                    Background="#8B2740"
                                    BorderBrush="#A3495E"
                                    Margin="0,0,8,0"
                                    Click="StopBenchmark_Click" />
                            <Button Content="{local:Loc OpenOutputFolder}"
                                    Style="{StaticResource BenchmarkButtonStyle}"
                                    Click="OpenOutputFolder_Click"
                                    IsEnabled="{Binding HasResults}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource BenchmarkCardStyle}">
                <StackPanel>
                    <TextBlock Text="{local:Loc CurrentStage}"
                               Style="{StaticResource BenchmarkSectionTitleStyle}" />
                    <TextBlock Text="{Binding CurrentCaseText}"
                               Margin="0,6,0,0"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CurrentStatus}"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <ProgressBar Height="18"
                                 Margin="0,12,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding CurrentProgress, Mode=OneWay}" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc Elapsed}"
                                           Style="{StaticResource BenchmarkCaptionStyle}" />
                                <TextBlock Text="{Binding CurrentElapsedText}"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ETA}"
                                           Style="{StaticResource BenchmarkCaptionStyle}" />
                                <TextBlock Text="{Binding CurrentEtaText}"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding CurrentDetail}"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource BenchmarkCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{local:Loc BenchmarkCurrentStep}"
                               Style="{StaticResource BenchmarkSectionTitleStyle}" />
                    <Border Grid.Row="1"
                            Background="#0E1628"
                            BorderBrush="#223552"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14,12"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding StepSummary}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding CurrentCaseText}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource BenchmarkCardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{local:Loc BenchmarkChartsWindowTitle}"
                               Style="{StaticResource BenchmarkSectionTitleStyle}" />
                    <TextBlock Text="{local:Loc BenchmarkChartsHint}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Button Content="{local:Loc BenchmarkChartsOpen}"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource BenchmarkButtonStyle}"
                            Click="OpenCharts_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
