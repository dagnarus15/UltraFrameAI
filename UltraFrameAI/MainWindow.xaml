                                   AllowsTransparency="True"
                                   StaysOpen="True"
                                   PopupAnimation="Fade"
                                   IsOpen="False">
                                <Border x:Name="BrowseInputPopupBorder"
                                        Margin="0,8,0,0"
                                        Padding="12"
                                        CornerRadius="18"
                                        Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        Opacity="0"
                                        RenderTransformOrigin="0.5,0">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="BrowseInputPopupScale" ScaleX="0.96" ScaleY="0.96" />
                                            <TranslateTransform x:Name="BrowseInputPopupTranslate" Y="10" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <StackPanel MinWidth="220">
                                        <TextBlock Text="{local:Loc Browse}"
                                                   FontWeight="SemiBold"
                                                   Margin="4,0,4,10" />
                                        <Button Content="{local:Loc BrowseFolder}"
                                                Click="BrowseFolderChoice_Click"
                                                Style="{StaticResource LanguageMenuButtonStyle}"
                                                Margin="0,0,0,6" />
                                        <Button Content="{local:Loc BrowseFile}"
                                                Click="BrowseFileChoice_Click"
                                                Style="{StaticResource LanguageMenuButtonStyle}" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{local:Loc Codec}" Style="{StaticResource CaptionStyle}" />
                                <ComboBox ItemsSource="{Binding CodecOptions}"
                                          SelectedItem="{Binding SelectedCodec}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{local:Loc Target}" Style="{StaticResource CaptionStyle}" />
                                <ComboBox ItemsSource="{Binding TargetOptions}"
                                          SelectedItem="{Binding SelectedTarget}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,2,0,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="48" />
                            </Grid.RowDefinitions>
                            <Button Content="{local:Loc StartBatch}"
                                    Command="{Binding StartCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Height="48"
                                    FontSize="18"
                                    IsEnabled="{Binding CanStartAll}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Opacity" Value="0.55" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanStartAll}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="{local:Loc StartSelected}"
                                    Command="{Binding StartSelectedCommand}"
                                    Background="#16243D"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Height="48"
                                    FontSize="18"
                                    Grid.Row="2"
                                    IsEnabled="{Binding CanStartSelected}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Opacity" Value="0.58" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanStartSelected}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Content="{local:Loc Stop}"
                                    Command="{Binding CancelCommand}"
                                    Background="#7A2630"
                                    BorderBrush="#C34B57"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Height="104"
                                    FontSize="18"
                                    Grid.RowSpan="3"
                                    Visibility="Collapsed">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>




                        <Button x:Name="SettingsButton"
                                Content="{local:Loc Additional}"
                                Click="AdditionalButton_Click"
                                MinWidth="132"
                                Padding="14,11"
                                Background="#16243D"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                ToolTip="{local:Loc AdditionalHint}"
                                Margin="0,0,0,10" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc LastRunResultsTitle}" FontSize="18" FontWeight="SemiBold" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Elapsed}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding LastRunElapsed}" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{local:Loc AverageFps}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding LastRunFps}" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc ProcessedFiles}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding LastRunProcessedFiles}" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="QueuePanelBorder"
                    Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    CornerRadius="18"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="210" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#13203A" Padding="18,16,12,16" CornerRadius="18,18,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Queue}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding QueueSummary}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Grid.Row="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{local:Loc DeleteSelected}"
                                            Click="DeleteSelected_Click"
                                            Padding="14,7"
                                            MinWidth="132"
                                            HorizontalAlignment="Right"
                                            Background="#2A1B21"
                                            BorderBrush="#5A2B34"
                                            Foreground="{StaticResource DangerBrush}"
                                            IsEnabled="{Binding CanDeleteSelected}" />
                                    <Button Grid.Column="2"
                                            Content="{local:Loc DeleteAll}"
                                            Click="DeleteAll_Click"
                                            Padding="14,7"
                                            MinWidth="108"
                                            HorizontalAlignment="Right"
                                            Background="#2A2218"
                                            BorderBrush="#6A4320"
                                            Foreground="{StaticResource WarningBrush}"
                                            IsEnabled="{Binding CanDeleteAll}" />
                                </Grid>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding CurrentFileName}"
                                       HorizontalAlignment="Right"
                                       MaxWidth="520"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="QueueGrid"
                              ItemsSource="{Binding Items}"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeight="28"
                              RowStyle="{StaticResource {x:Type DataGridRow}}"
                              CellStyle="{StaticResource {x:Type DataGridCell}}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Checked="QueueItemCheckChanged"
                                                      Unchecked="QueueItemCheckChanged">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource QueueSelectGlyphStyle}" />
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{local:Loc QueueItem}" Binding="{Binding Title}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{local:Loc QueueStatus}" Binding="{Binding StatusLabel}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="TextWrapping" Value="Wrap" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="2"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#223552"
                                  ShowsPreview="True"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Cursor="SizeNS" />

                    <Border Grid.Row="3"
                            Background="#0E1628"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1,1,1,1"
                            CornerRadius="0,0,18,18"
                            ClipToBounds="True"
                            Padding="0"
                            Margin="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#13203A" Padding="18,10" CornerRadius="0,0,0,0">
                                <TextBlock Text="{local:Loc Log}" FontSize="18" FontWeight="SemiBold" />
                            </Border>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Background="#13203A" Padding="18,10,18,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding LogLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="18,8,18,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Time}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Top"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Message}"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Top" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              x:Name="AdditionalOverlayRoot"
              Background="#C00F172A"
              Visibility="Collapsed"
              Panel.ZIndex="40"
              IsVisibleChanged="AdditionalOverlay_IsVisibleChanged">
            <Border x:Name="AdditionalOverlayBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="1020"
                    MaxHeight="690"
                    Padding="22"
                    CornerRadius="20"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="AdditionalOverlayScale" ScaleX="0.96" ScaleY="0.96" />
                        <TranslateTransform x:Name="AdditionalOverlayTranslate" Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{local:Loc Additional}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Button Grid.Column="1"
                                Width="34"
                                Height="34"
                                Padding="0"
                                Click="AdditionalClose_Click"
                                Background="#16243D"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE10A;"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="0.95*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{local:Loc OutputFolderLabel}"
                                       Style="{StaticResource CaptionStyle}"
                                       Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        Content="{local:Loc Browse}"
                                        Margin="10,0,0,0"
                                        Width="92"
                                        Command="{Binding BrowseOutputCommand}" />
                            </Grid>

    

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="{local:Loc Codec}" Style="{StaticResource CaptionStyle}" />
                                    <ComboBox ItemsSource="{Binding CodecOptions}"
                                              SelectedItem="{Binding SelectedCodec}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,0,8">
                                    <TextBlock>
                                        <Run Text="{local:Loc Target}" />
                                        <Run Text=" (" />
                                        <Run Text="{local:Loc Resolution}" />
                                        <Run Text=")" />
                                    </TextBlock>
                                    <ComboBox ItemsSource="{Binding TargetOptions}"
                                              SelectedItem="{Binding SelectedTarget}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="4" Margin="0,0,0,8">
                                    <TextBlock Text="{local:Loc Container}" Style="{StaticResource CaptionStyle}" />
                                    <ComboBox ItemsSource="{Binding ContainerOptions}"
                                              SelectedItem="{Binding SelectedContainer}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{local:Loc FFmpegThreads}" Style="{StaticResource CaptionStyle}" />
                                    <TextBox Text="{Binding FfmpegThreadsText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{local:Loc UpscalerJobs}" Style="{StaticResource CaptionStyle}" />
                                    <TextBox Text="{Binding UpscalerThreadsText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="{local:Loc TileSize}" Style="{StaticResource CaptionStyle}" />
                                    <TextBox Text="{Binding TileSizeText, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <WrapPanel Margin="0,0,0,12">
                                <CheckBox Content="{local:Loc OverwriteExistingOutput}" IsChecked="{Binding Overwrite}" />
                            </WrapPanel>

                            <Button Content="{local:Loc OpenOutputFolder}"
                                    Command="{Binding OpenOutputCommand}"
