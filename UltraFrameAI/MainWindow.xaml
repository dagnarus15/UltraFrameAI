                            <Button Content="{local:Loc Benchmark}"
                                    Click="BenchmarkButton_Click"
                                    MinWidth="132"
                                    Padding="14,11"
                                    Background="#16243D"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    ToolTip="{local:Loc BenchmarkHint}"
                                    Margin="0,10,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <CheckBox Content="{local:Loc AntiFlicker}"
                                      IsChecked="{Binding UseAntiFlicker}" />
                            <TextBlock Text="{local:Loc AntiFlickerHint}"
                                       Margin="0,6,0,12"
                                       Style="{StaticResource CaptionStyle}"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{local:Loc AntiFlickerPreset}"
                                       Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{local:Loc AntiFlickerPresetHint}"
                                       Style="{StaticResource CaptionStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,10" />

                            <StackPanel IsEnabled="{Binding UseAntiFlicker}">
                                <Button Command="{Binding SetContentModeCommand}"
                                        CommandParameter="Anime"
                                        Style="{StaticResource AnimePresetCardStyle}"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch">
                                    <Button.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26"
                                                    Height="26"
                                                    Background="#3B78B8"
                                                    CornerRadius="13"
                                                    VerticalAlignment="Top">
                                                <Viewbox Stretch="Uniform">
                                                    <Canvas Width="14" Height="14">
                                                        <Path Fill="White"
                                                              Opacity="0.92"
                                                              Data="M7,0.5 L9,5.1 L14,5.6 L10.2,8.9 L11.4,13.5 L7,10.9 L2.6,13.5 L3.8,8.9 L0,5.6 L5,5.1 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{local:Loc ContentModeAnime}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{local:Loc AntiFlickerAnimeHint}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Button Content="{local:Loc AntiFlickerUltra}"
                                                            Command="{Binding SetContentModeCommand}"
                                                            CommandParameter="AnimeUltra"
                                                            HorizontalAlignment="Left">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource PresetMiniButtonStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedContentMode}" Value="AnimeUltra">
                                                                        <Setter Property="Background" Value="#342069" />
                                                                        <Setter Property="BorderBrush" Value="#C5B0FF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                <TextBlock Text="{local:Loc AntiFlickerUltraHint}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Button.Content>
                                </Button>

                                <Button Command="{Binding SetContentModeCommand}"
                                        CommandParameter="Video"
                                        Style="{StaticResource VideoPresetCardStyle}"
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch">
                                    <Button.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26"
                                                    Height="26"
                                                    Background="#5D7F96"
                                                    CornerRadius="13"
                                                    VerticalAlignment="Top">
                                                <Viewbox Stretch="Uniform">
                                                    <Canvas Width="16" Height="12">
                                                        <Rectangle Width="16"
                                                                   Height="12"
                                                                   RadiusX="2"
                                                                   RadiusY="2"
                                                                   Fill="White"
                                                                   Opacity="0.18" />
                                                        <Polygon Fill="White"
                                                                 Opacity="0.9"
                                                                 Points="4.8,2.3 11.8,6 4.8,9.7" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{local:Loc ContentModeVideo}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{local:Loc AntiFlickerVideoHint}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Button.Content>
                                </Button>

                                <Button Command="{Binding SetContentModeCommand}"
                                        CommandParameter="Faces"
                                        Style="{StaticResource FacesPresetCardStyle}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Content>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26"
                                                    Height="26"
                                                    Background="#748999"
                                                    CornerRadius="13"
                                                    VerticalAlignment="Top">
                                                <Viewbox Stretch="Uniform">
                                                    <Canvas Width="14" Height="14">
                                                        <Ellipse Width="6.2"
                                                                 Height="6.2"
                                                                 Canvas.Left="3.9"
                                                                 Canvas.Top="0.6"
                                                                 Fill="White"
                                                                 Opacity="0.92" />
                                                        <Path Fill="White"
                                                              Opacity="0.88"
                                                              Data="M2,13 C2,10.2 4.2,8 7,8 H9 C11.8,8 14,10.2 14,13 V15 H2 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{local:Loc ContentModeFaces}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{local:Loc AntiFlickerFacesHint}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Button.Content>
                                </Button>
                            </StackPanel>

                            <DockPanel Margin="0,12,0,0">
                                <TextBlock Text="{local:Loc AntiFlickerStrength}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding AntiFlickerStrength, StringFormat={}{0:0}%}"
                                           Style="{StaticResource CaptionStyle}" />
                            </DockPanel>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding AntiFlickerStrength, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              x:Name="ScanOverlayRoot"
              Background="#9E0F172A"
              Visibility="Collapsed"
              Panel.ZIndex="20">
            <Border x:Name="ScanPopupBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420"
                    Padding="22"
                    CornerRadius="20"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ScanPopupScale" ScaleX="0.96" ScaleY="0.96" />
                        <TranslateTransform x:Name="ScanPopupTranslate" Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel>
                    <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="{local:Loc ScanningFolder}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Ellipse x:Name="ScanPulse"
                                 Width="10"
                                 Height="10"
                                 Margin="10,8,0,0"
                                 HorizontalAlignment="Right"
                                 Fill="{StaticResource AccentBrush}" />
                    </DockPanel>
                    <TextBlock Text="{Binding ScanStatusText}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanCurrentFolder}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanFolderText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanCurrentFile}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanCurrentFileText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanFoundVideos}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanFoundText}"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ProgressBar Height="16"
                                 Margin="0,16,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ScanProgress, Mode=OneWay}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ScanDetailText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="{local:Loc Cancel}"
                                Command="{Binding CancelCommand}"
                                MinWidth="92"
                                Padding="12,7"
                                Margin="12,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              x:Name="DeleteOverlayRoot"
              Background="#9E0F172A"
              Visibility="{Binding IsDeleteConfirmVisible, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="21"
              IsVisibleChanged="DeleteOverlay_IsVisibleChanged">
            <Border x:Name="DeletePopupBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    Padding="22"
                    CornerRadius="20"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="DeletePopupScale" ScaleX="0.96" ScaleY="0.96" />
                        <TranslateTransform x:Name="DeletePopupTranslate" Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel>
                    <DockPanel Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,7,10,0"
                                     Fill="{StaticResource WarningBrush}" />
                            <TextBlock Text="{local:Loc DeleteAllConfirmTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="{local:Loc DeleteAllConfirmMessage}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Border Background="#0E1628"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,16,0,0">
                        <TextBlock Text="{Binding QueueSummary}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="2"
                                Content="{local:Loc Cancel}"
                                Click="DeleteConfirmCancel_Click"
                                MinWidth="96"
                                Padding="14,8"
                                Background="#16243D"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        <Button Grid.Column="4"
                                Content="{local:Loc DeleteAll}"
                                Click="DeleteConfirmDelete_Click"
                                MinWidth="108"
                                Padding="14,8"
                                Background="#2A1B21"
                                BorderBrush="#5A2B34"
                                Foreground="{StaticResource DangerBrush}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>





