<Window x:Class="UltraFrameAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{local:Loc AppTitle}"
        Icon="pack://application:,,,/images/icon.png"
        Width="1400"
        Height="920"
        MinWidth="1180"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewMouseDown="Window_PreviewMouseDown"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        DragLeave="Window_DragLeave"
        DragOver="Window_DragOver">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:LanguageEqualsConverter x:Key="LanguageEqualsConverter" />
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#0E1628" />
            <Setter Property="AlternatingRowBackground" Value="#111C33" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#223552" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#13203A" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0E1628" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E1628" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#0E1628" />
                </Trigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#102E22" />
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSkipped}" Value="True">
                    <Setter Property="Background" Value="#1D2430" />
                    <Setter Property="BorderBrush" Value="#4A5A72" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsInterrupted}" Value="True">
                    <Setter Property="Background" Value="#1A2534" />
                    <Setter Property="BorderBrush" Value="#3C4F67" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
                <DataTrigger Binding="{Binding IsInterrupted}" Value="True">
                    <Setter Property="Foreground" Value="#F0B35E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSkipped}" Value="True">
                    <Setter Property="Foreground" Value="#C7D4E7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QueueSelectGlyphStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#35517A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Root"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Path x:Name="CheckMark"
                                      Data="M 3.5 10 L 7.5 14 L 15.5 6.2"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#13253F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#17324F" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="TextBlock" x:Key="CaptionStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="Border" x:Key="DropZoneStyle">
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#35517A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDropTargetActive}" Value="True">
                    <Setter Property="Background" Value="#13253F" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LanguageMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22375B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16243D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetCardButtonStyle" TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="MinHeight" Value="86" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#121E34" />
            <Setter Property="BorderBrush" Value="#28415F" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="AnimePresetCardStyle" TargetType="Button" BasedOn="{StaticResource PresetCardButtonStyle}">
            <Setter Property="Background" Value="#10253B" />
            <Setter Property="BorderBrush" Value="#2A5B93" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedContentMode}" Value="Anime">
                    <Setter Property="Background" Value="#163A5D" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PresetMiniButtonStyle" TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="#1A1230" />
            <Setter Property="BorderBrush" Value="#7C5FD9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="VideoPresetCardStyle" TargetType="Button" BasedOn="{StaticResource PresetCardButtonStyle}">
            <Setter Property="Background" Value="#152737" />
            <Setter Property="BorderBrush" Value="#35556D" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedContentMode}" Value="Video">
                    <Setter Property="Background" Value="#20384B" />
                    <Setter Property="BorderBrush" Value="#7AA4C8" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FacesPresetCardStyle" TargetType="Button" BasedOn="{StaticResource PresetCardButtonStyle}">
            <Setter Property="Background" Value="#1A2631" />
            <Setter Property="BorderBrush" Value="#465868" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedContentMode}" Value="Faces">
                    <Setter Property="Background" Value="#253241" />
                    <Setter Property="BorderBrush" Value="#9BB0C0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="ScanPopupIn">
            <DoubleAnimation Storyboard.TargetName="ScanPopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14"
                             To="0"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ScanPulseLoop" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ScanPulse"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35"
                             To="1"
                             Duration="0:0:0.80" />
        </Storyboard>

        <Storyboard x:Key="ScanPopupOut">
            <DoubleAnimation Storyboard.TargetName="ScanPopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="14"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="DeletePopupIn">
            <DoubleAnimation Storyboard.TargetName="DeletePopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14"
                             To="0"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="DeletePopupOut">
            <DoubleAnimation Storyboard.TargetName="DeletePopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="14"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Padding="22" Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#16233D" Offset="0" />
                    <GradientStop Color="#0E1628" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#243451" />
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{local:Loc AppTitle}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="{local:Loc Subtitle}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="900" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid>
                        <Button x:Name="LanguageButton"
                                Width="42"
                                Height="32"
                                HorizontalAlignment="Right"
                                Padding="0"
                                Background="#13203A"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                ToolTip="{local:Loc Language}"
                                Click="LanguageButton_Click">
                            <Image Source="{Binding CurrentLanguageFlagPath}" Width="24" Height="16" />
                        </Button>
                        <Popup x:Name="LanguagePopup"
                               PlacementTarget="{Binding ElementName=LanguageButton}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               DataContext="{Binding}">
                            <Border x:Name="LanguagePopupBorder"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="LanguagePopupScale" ScaleX="0.96" ScaleY="0.96" />
                                        <TranslateTransform x:Name="LanguagePopupTranslate" Y="10" />
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <StackPanel MinWidth="180">
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="English"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=English}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-en.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageEnglish}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="Russian"
                                            Margin="0,2,0,0"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=Russian}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-ru.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageRussian}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="German"
                                            Margin="0,2,0,0"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=German}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-de.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageGerman}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Workspace}" FontSize="18" FontWeight="SemiBold" />
                        <Border Style="{StaticResource DropZoneStyle}">
                            <StackPanel>
                                <TextBlock Text="{local:Loc DropZoneTitle}" FontWeight="SemiBold" />
                                <TextBlock Text="{local:Loc DropZoneHelp}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{local:Loc RootFolder}" Style="{StaticResource CaptionStyle}" />
                        <Grid Margin="0,6,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RootFolderTextBox" Text="{Binding RootFolder, UpdateSourceTrigger=PropertyChanged}" MinWidth="0" />
                            <Button x:Name="BrowseInputButton"
                                    Grid.Column="1"
                                    Content="{local:Loc Browse}"
                                    Margin="10,0,0,0"
                                    Width="92"
                                    Click="BrowseInputButton_Click" />
                            <Grid Grid.Column="2" Margin="10,0,0,0">
                                <Button x:Name="RecentFoldersButton"
                                        Width="42"
                                        Height="36"
                                        Padding="0"
                                        ToolTip="{local:Loc RecentFolders}"
                                        Click="RecentFoldersButton_Click">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE72C;"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Popup x:Name="RecentFoldersPopup"
                                       PlacementTarget="{Binding ElementName=RecentFoldersButton}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       DataContext="{Binding}">
                                    <Border x:Name="RecentFoldersPopupBorder"
                                            Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="4"
                                            Margin="0,4,0,0"
                                            Opacity="0"
                                            RenderTransformOrigin="0.5,0">
                                        <Border.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="RecentFoldersPopupScale" ScaleX="0.96" ScaleY="0.96" />
                                                <TranslateTransform x:Name="RecentFoldersPopupTranslate" Y="10" />
                                            </TransformGroup>
                                        </Border.RenderTransform>
                                        <StackPanel MinWidth="360" MaxWidth="520">
                                            <TextBlock Text="{local:Loc RecentFolders}"
                                                       FontWeight="SemiBold"
                                                       Margin="8,6,8,10" />
                                            <ItemsControl ItemsSource="{Binding RecentRootFolders}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="RecentFolder_Click"
                                                                Margin="0,0,0,4">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="Background" Value="#2B4D7A" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Content>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding FolderPath}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="11"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,3,0,0" />
                                                                </StackPanel>
                                                            </Button.Content>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Popup x:Name="BrowseInputPopup"
                                   PlacementTarget="{Binding ElementName=BrowseInputButton}"
