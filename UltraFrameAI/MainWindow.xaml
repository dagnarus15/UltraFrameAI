<Window x:Class="UltraFrameAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{local:Loc AppTitle}"
        Icon="pack://application:,,,/images/icon.png"
        Width="1400"
        Height="920"
        MinWidth="1180"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        PreviewMouseDown="Window_PreviewMouseDown"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        DragLeave="Window_DragLeave"
        DragOver="Window_DragOver">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:LanguageEqualsConverter x:Key="LanguageEqualsConverter" />
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#0E1628" />
            <Setter Property="AlternatingRowBackground" Value="#111C33" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#13203A" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style TargetType="TextBlock" x:Key="CaptionStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="Border" x:Key="DropZoneStyle">
            <Setter Property="Background" Value="#0E1628" />
            <Setter Property="BorderBrush" Value="#35517A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDropTargetActive}" Value="True">
                    <Setter Property="Background" Value="#13253F" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LanguageMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22375B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16243D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="ScanPopupIn">
            <DoubleAnimation Storyboard.TargetName="ScanPopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14"
                             To="0"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ScanPulseLoop" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="ScanPulse"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35"
                             To="1"
                             Duration="0:0:0.80" />
        </Storyboard>

        <Storyboard x:Key="ScanPopupOut">
            <DoubleAnimation Storyboard.TargetName="ScanPopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScanPopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="14"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="DeletePopupIn">
            <DoubleAnimation Storyboard.TargetName="DeletePopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.18" />
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.96"
                             To="1"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14"
                             To="0"
                             Duration="0:0:0.20">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="DeletePopupOut">
            <DoubleAnimation Storyboard.TargetName="DeletePopupBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="0.96"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DeletePopupTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="14"
                             Duration="0:0:0.10">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="220" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Padding="22" Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#16233D" Offset="0" />
                    <GradientStop Color="#0E1628" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#243451" />
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{local:Loc AppTitle}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="{local:Loc Subtitle}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="900" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid>
                        <Button x:Name="LanguageButton"
                                Width="42"
                                Height="32"
                                HorizontalAlignment="Right"
                                Padding="0"
                                Background="#13203A"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                ToolTip="{local:Loc Language}"
                                Click="LanguageButton_Click">
                            <Image Source="{Binding CurrentLanguageFlagPath}" Width="24" Height="16" />
                        </Button>
                        <Popup x:Name="LanguagePopup"
                               PlacementTarget="{Binding ElementName=LanguageButton}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               DataContext="{Binding}">
                            <Border x:Name="LanguagePopupBorder"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="LanguagePopupScale" ScaleX="0.96" ScaleY="0.96" />
                                        <TranslateTransform x:Name="LanguagePopupTranslate" Y="10" />
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <StackPanel MinWidth="180">
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="English"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=English}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-en.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageEnglish}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="Russian"
                                            Margin="0,2,0,0"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=Russian}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-ru.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageRussian}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                    <Button Command="{Binding SetLanguageCommand}"
                                            CommandParameter="German"
                                            Margin="0,2,0,0"
                                            Click="LanguageChoice_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage, Converter={StaticResource LanguageEqualsConverter}, ConverterParameter=German}" Value="True">
                                                        <Setter Property="Background" Value="#2B4D7A" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="pack://application:,,,/images/flag-de.png" Width="18" Height="12" Margin="0,0,8,0" />
                                                <TextBlock Text="{local:Loc LanguageGerman}" />
                                            </StackPanel>
                                        </Button.Content>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <TextBlock Text="{Binding StatusSummary}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastHeartbeat}" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc Workspace}" FontSize="18" FontWeight="SemiBold" />
                        <Border Style="{StaticResource DropZoneStyle}">
                            <StackPanel>
                                <TextBlock Text="{local:Loc DropZoneTitle}" FontWeight="SemiBold" />
                                <TextBlock Text="{local:Loc DropZoneHelp}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{local:Loc RootFolder}" Style="{StaticResource CaptionStyle}" />
                        <Grid Margin="0,6,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RootFolderTextBox" Text="{Binding RootFolder, UpdateSourceTrigger=PropertyChanged}" MinWidth="0" />
                            <Button Grid.Column="1" Content="{local:Loc Browse}" Margin="10,0,0,0" Width="92" Command="{Binding BrowseRootCommand}" />
                            <Grid Grid.Column="2" Margin="10,0,0,0">
                                <Button x:Name="RecentFoldersButton"
                                        Width="42"
                                        Height="36"
                                        Padding="0"
                                        ToolTip="{local:Loc RecentFolders}"
                                        Click="RecentFoldersButton_Click">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE72C;"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                                <Popup x:Name="RecentFoldersPopup"
                                       PlacementTarget="{Binding ElementName=RecentFoldersButton}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       DataContext="{Binding}">
                                    <Border x:Name="RecentFoldersPopupBorder"
                                            Background="{StaticResource CardBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="4"
                                            Margin="0,4,0,0"
                                            Opacity="0"
                                            RenderTransformOrigin="0.5,0">
                                        <Border.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="RecentFoldersPopupScale" ScaleX="0.96" ScaleY="0.96" />
                                                <TranslateTransform x:Name="RecentFoldersPopupTranslate" Y="10" />
                                            </TransformGroup>
                                        </Border.RenderTransform>
                                        <StackPanel MinWidth="360" MaxWidth="520">
                                            <TextBlock Text="{local:Loc RecentFolders}"
                                                       FontWeight="SemiBold"
                                                       Margin="8,6,8,10" />
                                            <ItemsControl ItemsSource="{Binding RecentRootFolders}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="RecentFolder_Click"
                                                                Margin="0,0,0,4">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource LanguageMenuButtonStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="Background" Value="#2B4D7A" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Content>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding FolderPath}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                                               FontSize="11"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,3,0,0" />
                                                                </StackPanel>
                                                            </Button.Content>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>

                        <Button Content="{local:Loc StartBatch}"
                                Command="{Binding StartCommand}"
                                Background="{StaticResource AccentBrush}"
                                Height="48"
                                FontSize="18"
                                Margin="0,2,0,6" />

                        <TextBlock Text="{local:Loc QuickStartHint}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <Expander Header="{local:Loc Advanced}"
                                  IsExpanded="False">
                            <StackPanel>
                                <Grid Margin="0,8,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Content="{local:Loc Browse}" Margin="10,0,0,0" Width="92" Command="{Binding BrowseOutputCommand}" />
                                </Grid>

                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,0,10">
                                        <TextBlock Text="{local:Loc Codec}" Style="{StaticResource CaptionStyle}" />
                                        <ComboBox ItemsSource="{Binding CodecOptions}"
                                                  SelectedItem="{Binding SelectedCodec}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,0,10">
                                        <TextBlock Text="{local:Loc Target}" Style="{StaticResource CaptionStyle}" />
                                        <ComboBox ItemsSource="{Binding TargetOptions}"
                                                  SelectedItem="{Binding SelectedTarget}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>

                                <WrapPanel Margin="0,0,0,8">
                                    <StackPanel Width="112" Margin="0,0,12,10">
                                        <TextBlock Text="{local:Loc FFmpegThreads}" Style="{StaticResource CaptionStyle}" />
                                        <TextBox Text="{Binding FfmpegThreadsText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Width="112" Margin="0,0,12,10">
                                        <TextBlock Text="{local:Loc UpscalerJobs}" Style="{StaticResource CaptionStyle}" />
                                        <TextBox Text="{Binding UpscalerThreadsText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Width="112" Margin="0,0,0,10">
                                        <TextBlock Text="{local:Loc TileSize}" Style="{StaticResource CaptionStyle}" />
                                        <TextBox Text="{Binding TileSizeText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </WrapPanel>

                                <WrapPanel Margin="0,0,0,10">
                                    <CheckBox Content="{local:Loc OverwriteExistingOutput}" IsChecked="{Binding Overwrite}" />
                                    <CheckBox Content="{local:Loc KeepTempFolders}" IsChecked="{Binding KeepTemp}" />
                                </WrapPanel>

                                <Button Content="{local:Loc OpenOutputFolder}"
                                        Command="{Binding OpenOutputCommand}"
                                        Margin="0,0,0,2" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{local:Loc CurrentStage}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentStage}" Margin="0,6,0,8" Foreground="{StaticResource TextSecondaryBrush}" />
                        <ProgressBar Height="18" Value="{Binding OverallProgress, Mode=OneWay}" Minimum="0" Maximum="100" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Elapsed}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ElapsedText}" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{local:Loc ETA}" Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding EtaText}" FontSize="18" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <Expander Header="{local:Loc ProgressDetails}"
                                  Margin="0,14,0,0">
                            <Border Background="#0E1628" CornerRadius="12" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc Phase}" Style="{StaticResource CaptionStyle}" />
                                        <TextBlock Text="{Binding CurrentStatusLine}" Margin="0,4,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{local:Loc StepDuration}" Style="{StaticResource CaptionStyle}" />
                                        <TextBlock Text="{Binding StageDurationText}" Margin="0,4,0,0" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Expander>

                        <Border Background="#0E1628" CornerRadius="12" Padding="12" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentItemTitle}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentItemDetail}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#13203A" Padding="18,16,12,16" CornerRadius="18,18,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{local:Loc Queue}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding QueueSummary}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Grid.Row="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{local:Loc DeleteSelected}"
                                            Click="DeleteSelected_Click"
                                            Padding="14,7"
                                            MinWidth="132"
                                            HorizontalAlignment="Right"
                                            Background="#2A1B21"
                                            BorderBrush="#5A2B34"
                                            Foreground="{StaticResource DangerBrush}"
                                            IsEnabled="{Binding CanDeleteSelected}" />
                                    <Button Grid.Column="2"
                                            Content="{local:Loc DeleteAll}"
                                            Click="DeleteAll_Click"
                                            Padding="14,7"
                                            MinWidth="108"
                                            HorizontalAlignment="Right"
                                            Background="#2A2218"
                                            BorderBrush="#6A4320"
                                            Foreground="{StaticResource WarningBrush}"
                                            IsEnabled="{Binding CanDeleteAll}" />
                                </Grid>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding CurrentFileName}"
                                       HorizontalAlignment="Right"
                                       MaxWidth="520"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Grid>
                    </Border>

                    <DataGrid x:Name="QueueGrid"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem}"
                              PreviewKeyDown="QueueGrid_PreviewKeyDown"
                              SelectionChanged="QueueGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{local:Loc QueueIndex}" Binding="{Binding Index}" Width="44" />
                            <DataGridTextColumn Header="{local:Loc QueueItem}" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="{local:Loc QueueStage}" Binding="{Binding Stage}" Width="*" />
                            <DataGridTemplateColumn Header="{local:Loc QueueProgress}" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <ProgressBar Height="14" Value="{Binding Progress}" Minimum="0" Maximum="100" />
                                            <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" />
                                        </Grid>
                                    </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{local:Loc QueueElapsed}" Binding="{Binding ElapsedText}" Width="110" />
                            <DataGridTextColumn Header="{local:Loc QueueETA}" Binding="{Binding EtaText}" Width="110" />
                            <DataGridTextColumn Header="{local:Loc QueueOutput}" Binding="{Binding OutputState}" Width="*" />
                            <DataGridTemplateColumn Header="" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Padding="0"
                                                Width="32"
                                                Height="28"
                                                Background="#2A1B21"
                                                BorderBrush="#5A2B34"
                                                Foreground="{StaticResource DangerBrush}"
                                                ToolTip="{local:Loc DeleteItem}"
                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE74D;"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3"
              x:Name="ScanOverlayRoot"
              Background="#9E0F172A"
              Visibility="Collapsed"
              Panel.ZIndex="20">
            <Border x:Name="ScanPopupBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420"
                    Padding="22"
                    CornerRadius="20"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ScanPopupScale" ScaleX="0.96" ScaleY="0.96" />
                        <TranslateTransform x:Name="ScanPopupTranslate" Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel>
                    <DockPanel Margin="0,0,0,2">
                    <TextBlock Text="{local:Loc ScanningFolder}"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <Ellipse x:Name="ScanPulse"
                                 Width="10"
                                 Height="10"
                                 Margin="10,8,0,0"
                                 HorizontalAlignment="Right"
                                 Fill="{StaticResource AccentBrush}" />
                    </DockPanel>
                    <TextBlock Text="{Binding ScanStatusText}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanCurrentFolder}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanFolderText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanCurrentFile}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanCurrentFileText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#0E1628" CornerRadius="12" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{local:Loc ScanFoundVideos}"
                                           Style="{StaticResource CaptionStyle}" />
                                <TextBlock Text="{Binding ScanFoundText}"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ProgressBar Height="16"
                                 Margin="0,16,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ScanProgress, Mode=OneWay}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ScanDetailText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="{local:Loc Cancel}"
                                Command="{Binding CancelCommand}"
                                MinWidth="92"
                                Padding="12,7"
                                Margin="12,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3"
              x:Name="DeleteOverlayRoot"
              Background="#9E0F172A"
              Visibility="{Binding IsDeleteConfirmVisible, Converter={StaticResource BoolToVisibility}}"
              Panel.ZIndex="21"
              IsVisibleChanged="DeleteOverlay_IsVisibleChanged">
            <Border x:Name="DeletePopupBorder"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    Padding="22"
                    CornerRadius="20"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="DeletePopupScale" ScaleX="0.96" ScaleY="0.96" />
                        <TranslateTransform x:Name="DeletePopupTranslate" Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel>
                    <DockPanel Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,7,10,0"
                                     Fill="{StaticResource WarningBrush}" />
                            <TextBlock Text="{local:Loc DeleteAllConfirmTitle}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Text="{local:Loc DeleteAllConfirmMessage}"
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <Border Background="#0E1628"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,16,0,0">
                        <TextBlock Text="{Binding QueueSummary}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="2"
                                Content="{local:Loc Cancel}"
                                Click="DeleteConfirmCancel_Click"
                                MinWidth="96"
                                Padding="14,8"
                                Background="#16243D"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}" />
                        <Button Grid.Column="4"
                                Content="{local:Loc DeleteAll}"
                                Click="DeleteConfirmDelete_Click"
                                MinWidth="108"
                                Padding="14,8"
                                Background="#2A1B21"
                                BorderBrush="#5A2B34"
                                Foreground="{StaticResource DangerBrush}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0" Margin="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#13203A" Padding="18,14" CornerRadius="18,18,0,0">
                    <TextBlock Text="{local:Loc Log}" FontSize="18" FontWeight="SemiBold" />
                </Border>
                <ListBox ItemsSource="{Binding LogLines}" Background="#0E1628" BorderThickness="0" Foreground="{StaticResource TextPrimaryBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="2,1" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
