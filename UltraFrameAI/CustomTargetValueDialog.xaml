<Window x:Class="UltraFrameAI.CustomTargetValueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraFrameAI"
        Title="{local:Loc CustomTargetDialogTitle}"
        Width="460"
        SizeToContent="Height"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent">
    <Border Background="{DynamicResource AppBgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="18"
            ClipToBounds="True">
        <Grid Margin="18">
            <Border Style="{StaticResource CardStyle}"
                    Padding="18"
                    Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{local:Loc CustomTargetDialogTitle}"
                               FontSize="22"
                               FontWeight="SemiBold" />

                    <TextBlock Grid.Row="2"
                               Text="{local:Loc CustomTargetDialogPrompt}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <TextBox x:Name="ValueTextBox"
                             Grid.Row="4"
                             Height="40"
                             VerticalContentAlignment="Center"
                             FontSize="16"
                             PreviewTextInput="ValueTextBox_PreviewTextInput" />

                    <StackPanel Grid.Row="6"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="{local:Loc Cancel}"
                                IsCancel="True"
                                MinWidth="120"
                                Margin="0,0,10,0"
                                Click="Cancel_Click" />
                        <Button Content="{local:Loc Apply}"
                                IsDefault="True"
                                MinWidth="120"
                                Background="{StaticResource AccentBrush}"
                                Click="Apply_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
